{
  "$comment": "Single source of design tokens shared between the Flutter app (AppColors / BaganzaEffects) and the SSR storefront, exported there as CSS custom properties (§7.2.6). Keep in sync with app_colors.dart and baganza_effects.dart.",
  "color": {
    "brandGreen": "#1E7A3C",
    "brandGreenDark": "#14532D",
    "brandGold": "#C9A227",
    "brandCrimson": "#9E1B32",
    "alert": "#C62828",
    "background": "#FFFFFF",
    "textPrimary": "#14532D",
    "textSecondary": "#1F2A24",
    "ambientAzure": "#EAF4FE",
    "ambientAzureHero": "#DDEEFC"
  },
  "gradient": {
    "ambient": "linear-gradient(180deg, #EAF4FE 0%, #FFFFFF 62%)",
    "hero": "linear-gradient(180deg, #DDEEFC 0%, #FFFFFF 70%)"
  },
  "glass": {
    "blurPx": 22,
    "fillOpacity": 0.72,
    "borderOpacity": 0.45,
    "radiusPx": 22,
    "solidFallbackOpacity": 0.96
  },
  "shadow": {
    "cardAmbient": "0 2px 8px rgba(0,0,0,0.05)",
    "cardDirectional": "0 12px 24px rgba(30,122,60,0.10)"
  },
  "motion": {
    "durationFastMs": 180,
    "durationStandardMs": 280,
    "durationPageMs": 450,
    "curveArrive": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "cardRadiusPx": 22
  },
  "rules": {
    "interactiveColor": "brandGreen",
    "ambientAzureUsage": "background wash only — never text or interactive",
    "goldUsage": "decorative only — never readable text",
    "glassForbiddenBehind": ["posology", "contraindications", "price", "checkoutTotals", "ministerialLogo"]
  }
}
