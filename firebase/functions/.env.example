# OPENAI_API_KEY=
# PHOTOROOM_API_KEY=
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_SECRET=
# SATISPAY_API_KEY=

# Customer assistant LLM (Fase 4B, §12.2 — OpenAI-compatible EU provider,
# e.g. Scaleway Generative APIs / OVHcloud AI Endpoints / Mistral La
# Plateforme). Model swap = config change, zero refactoring (ADR 0003).
# Without these the assistant runs in deterministic mock mode.
# LLM_BASE_URL=https://api.scaleway.ai/v1
# LLM_MODEL=qwen3-32b-instruct
# LLM_API_KEY=

# Embeddings for the catalog RAG (step 4B.2). Default to the LLM endpoint
# settings when unset; without a key a deterministic mock is used.
# EMBEDDING_DIMENSIONS truncates Matryoshka models (e.g. qwen3-embedding-8b)
# to match the Firestore vector index (dim 1024, hard limit 2048).
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=qwen3-embedding-8b
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_API_KEY=

# Firebase Functions environment (copy to .env for local emulator)
# FIREBASE_PROJECT_ID=dbfarmacia
